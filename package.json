{
  "name": "reelmark",
  "version": "0.1.0",
  "description": "Save YouTube videos and share them with followers",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker:dev": "tsx watch src/workers/placeholder.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "worker:start": "node dist/workers/placeholder.js",
    "migrate": "tsx migrations/run.ts"
  },
  "dependencies": {
