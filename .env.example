# Server
PORT=3000
NODE_ENV=development

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# YouTube Data API v3
YOUTUBE_API_KEY=

# Database
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_URL=
TEST_DATABASE_URL=

# Redis
REDIS_URL=
REDIS_TOKEN=

# App URL (used for OAuth redirects back to frontend)
APP_URL=http://localhost:5173